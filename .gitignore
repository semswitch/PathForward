# secrets — NEVER commit
.env
.env.local
*.pem
*.key

# python
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
*.egg-info/
build/
dist/
local.settings.json

# function deploy staging (assembled + removed by scripts/deploy_function_app.ps1)
functions/mint_mcp/.deploy/

# generated (reproducible via scripts/) — keep the repo clean
data/generated/

# node / web
web/node_modules/
web/dist/
web/.vite/
web/src/lib/fixture.json

# tour narration working files — stems + dry VO stay local; only the final
# mastered mix (web/public/narration/tour.mp3) and the manifest are committed
web/narration-work/
web/public/narration/*.wav

# os / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# agent workspace — never commit (planning, evidence, temp, logs)
.agents/
.kiro/
.worktrees/
.claude/
skills-lock.json

# stray pip cache from a mis-expanded %appdata% in a shell command
%appdata%/
.azure
