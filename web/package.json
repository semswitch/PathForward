{
  "name": "pathforward-web",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "description": "PathForward UI — human-first site with the live agentic Architecture Tour (React Flow + Tailwind v4 + Motion).",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "narration": "tsx scripts/generate-narration.ts",
    "narration:transcript": "tsx scripts/narration-transcript.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.5",
    "@fontsource-variable/jetbrains-mono": "^5.2.5",
    "@tailwindcss/vite": "^4.3.0",
    "@xyflow/react": "^12.11.0",
    "motion": "^12.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^15.0.0",
    "happy-dom": "^20.10.2",
    "microsoft-cognitiveservices-speech-sdk": "^1.42.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
