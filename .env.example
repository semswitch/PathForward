# PathForward — environment template. Copy to `.env` (gitignored) and fill in after Day-0 provisioning.
# The OFFLINE CORE ignores all of these; they are only read by the Azure layer.

# --- region / model (Day-0 verified: East US 2 + gpt-5.5) ---
PATHFORWARD_REGION=eastus2
AZURE_AI_MODEL_DEPLOYMENT=reasoning          # deployment name; underlying model gpt-5.5 (2026-04-24)

# --- Service principal (RG-scoped Owner) for keyless DefaultAzureCredential ---
AZURE_SUBSCRIPTION_ID=<subscription-id>
AZURE_TENANT_ID=<tenant-id>
AZURE_CLIENT_ID=<sp-app-id>
AZURE_CLIENT_SECRET=<sp-client-secret>       # SECRET — fill in .env only, never commit

# --- Foundry project (GA Responses API) ---
# Endpoint shape: https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=

# --- Azure AI Search (GA agentic retrieval, api-version 2026-04-01) ---
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX=pathforward-iq

# --- Microsoft Fabric (paid F2+ OR Power BI Premium P1+ capacity; OBO-only, no service principals) ---
FABRIC_WORKSPACE_ID=
FABRIC_ARTIFACT_ID=

# --- Voice Live (api-version 2026-04-10, agent mode, Entra auth) ---
VOICE_LIVE_ENDPOINT=

# --- MCP credential-mint server (public HTTPS ingress + Entra auth on Basic Agent Setup) ---
MCP_MINT_URL=
