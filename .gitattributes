# Normalize line endings: store text as LF in the repo and check out as LF on
# every platform, so Windows checkouts don't introduce CRLF churn.
* text=auto eol=lf

# Treat common binary assets as binary (never normalize or diff as text).
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
